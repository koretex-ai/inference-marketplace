{
  "name": "inference-marketplace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenRouter-style inference marketplace backed by a fleet of rented Macs (Apple Silicon first-class). Dispatcher + node-agent.",
  "scripts": {
    "prestart": "npm run bundle && npm run wallet:bundle",
    "start": "tsx src/dispatcher/index.ts",
    "predispatcher": "npm run bundle && npm run wallet:bundle",
    "dispatcher": "tsx src/dispatcher/index.ts",
    "agent": "tsx src/vendor/koretex-node/src/node-agent/cli.ts",
    "pair": "tsx src/vendor/koretex-node/src/node-agent/cli.ts pair",
    "bundle": "esbuild src/vendor/koretex-node/src/node-agent/cli.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/koretex-agent.cjs",
    "wallet:bundle": "esbuild src/dispatcher/wallet-client.ts --bundle --platform=browser --target=es2020 --format=iife --minify --define:process.env.NODE_ENV=\\\"production\\\" --outfile=dist/wallet.js",
    "e2e": "bash test/e2e.sh"
  },
  "dependencies": {
    "@phantom/browser-sdk": "^2.0.2",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "pg": "^8.13.1",
    "qrcode-terminal": "^0.12.0",
    "stripe": "^22.3.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
