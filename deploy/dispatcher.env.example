# Copy to /etc/macinference/dispatcher.env on the VPS (deploy script does this).
# Plain KEY=value lines (systemd EnvironmentFile format — no quotes, no export).
PORT=8787
# Comma-separated customer API keys (Bearer tokens customers send).
CUSTOMER_KEYS=sk-cust-CHANGEME
# Shared secret nodes must present to register. Must match the Mac agent's NODE_TOKEN.
NODE_TOKEN=CHANGEME
# Operator's Solana wallet address — the only wallet allowed into the /admin console (sign-in
# with Phantom). This is the easy way to view network data; no secret to manage.
ADMIN_WALLET=YourSolanaAddressHere
# Optional bearer for the raw /admin/ledger* JSON endpoints (scripts/cron). Closed-by-default:
# if unset, those JSON endpoints are denied. The /admin console uses ADMIN_WALLET, not this.
ADMIN_TOKEN=CHANGEME-long-random
# Durable ledger. Unset = in-memory (wiped on restart). In Coolify, use the database's
# INTERNAL connection string (Docker-network hostname), not the public host:port.
DATABASE_URL=postgres://USER:PASS@INTERNAL_HOST:5432/postgres

# ---- Credits / payments (M4 money-in) ----
# Solana RPC used to VERIFY USDC deposits on-chain (and proxied for the browser). A Helius/QuickNode
# URL carries an API key — treat it as a secret. Defaults to the public mainnet RPC if unset.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Wallet that RECEIVES customers' USDC (the admin fee wallet). Public address.
ADMIN_FEE_WALLET=YourUSDCReceivingAddressHere
# Peg: credits issued per 1 USDC. 10000 → 1 credit = $0.0001 (fine-grained enough to bill
# per-token inference in whole credits).
CREDITS_PER_USDC=10000
# Commitment for reading deposits: 'finalized' (safe, default) or 'confirmed' (faster).
SOLANA_COMMITMENT=finalized
# Override the USDC mint only for testing (defaults to mainnet USDC).
# USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ---- AEO/SEO site review (optional) ----
# OpenRouter API key for the /aeo-seo-review report generator. SECRET — server-side only.
# Unset = the review page shows but report generation is disabled ("not configured").
OPENROUTER_API_KEY=sk-or-CHANGEME
# Which OpenRouter model writes the report (open-weight). Defaults to DeepSeek V4.
# OPENROUTER_MODEL=deepseek/deepseek-v4-pro
# How many times a wallet may re-run its (single, free) site review per day (default 3).
# AEO_RUNS_PER_DAY=3
# Contact emails exempt from the one-site lock AND the daily cap (comma-separated) — for the
# operator generating example reports / case studies. Self-reported identity; keep it to our own.
# AEO_UNLIMITED_EMAILS=moreshkokane@gmail.com
# Review starts allowed per client IP per hour (the flow has no login; this bounds spend).
# AEO_STARTS_PER_IP_PER_HOUR=6
# Crawl caps: max pages per review (default 100, fetched ~6 at a time) and the whole-crawl
# wall-clock budget in ms (default 180000). Sites bigger than the cap get sampled.
# AEO_MAX_PAGES=100
# AEO_CRAWL_BUDGET_MS=180000

# ---- Stripe (card payments, optional) ----
# Lets customers top up credits by card instead of USDC. Leave BOTH unset to disable card payments
# (the "Pay with card" button stays hidden and only the crypto flow shows). Credits land in the same
# wallet balance at the same CREDITS_PER_USDC peg. Both values are SECRETS — keep them out of the repo.
# Secret API key (Stripe Dashboard → Developers → API keys). Use sk_test_… until you go live.
STRIPE_SECRET_KEY=sk_test_CHANGEME
# Signing secret for the webhook endpoint POST /credits/stripe/webhook (Dashboard → Webhooks, or the
# `stripe listen` CLI). Used to verify each event is really from Stripe. Subscribe to checkout.session.completed.
STRIPE_WEBHOOK_SECRET=whsec_CHANGEME
# Optional ceiling on a single card top-up, in USD (default 10000).
# STRIPE_MAX_USD=10000
